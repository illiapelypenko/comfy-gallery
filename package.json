{
  "name": "image-viewer",
  "version": "1.0.0",
  "main": "main.js",
  "scripts": {
    "dev": "concurrently \"vite\" \"wait-on http://localhost:5173 && electron .\"",
    "dev:debug": "concurrently \"vite\" \"wait-on http://localhost:5173 && electron . --remote-debugging-port=9222\"",
    "build": "vite build",
    "start": "npm run build && cross-env NODE_ENV=production electron .",
    "dist": "npm run build && electron-builder"
  },
  "build": {
    "appId": "com.yourname.image-viewer",
    "productName": "Image Viewer",
    "files": [
      "dist/**/*",
      "main.js",
      "preload.js"
    ],
    "win": {
      "target": "nsis"
    },
    "directories": {
      "output": "release"
    }
  },
  "dependencies": {
    "react": "^18.3.0",
    "react-dom": "^18.3.0"
  },
  "devDependencies": {
    "@vitejs/plugin-react": "^4.3.0",
    "concurrently": "^8.2.0",
    "cross-env": "^7.0.3",
    "electron": "^29.0.0",
    "electron-builder": "^24.13.3",
    "vite": "^5.4.0",
    "wait-on": "^7.2.0"
  }
}
